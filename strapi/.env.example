# Server
HOST=0.0.0.0
PORT=1337
# Öffentliche URL hinter dem Reverse Proxy (wird in config/server.ts verwendet)
PUBLIC_URL=https://example.com/healrise/app/cms

# Secrets — alle Werte generieren, z.B. mit: openssl rand -base64 32
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
# PFLICHT: JWT-Secret für users-permissions (kein Fallback im Code!)
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database — PostgreSQL
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=healrise
DATABASE_USERNAME=healrise
DATABASE_PASSWORD=tobemodified
DATABASE_SSL=false

# Seeds (nur Entwicklung!): legt Testuser + Demo-Inhalte an
SEED_DEMO=false

# Stripe (Testmodus zuerst: sk_test_... / whsec_...) — leer lassen = Checkout deaktiviert.
# Guardrail: im Testmodus KEINE Live-Keys (sk_live_/pk_live_) verwenden. Readiness
# lokal prüfbar via strapi/src/stripe-config.ts (validateStripeConfig), ohne Netz-/
# Stripe-Aufrufe. Echte Keys nur in strapi/.env, niemals im Repo.
#
# Key-Auflösung (resolveStripeSecretKey/resolveStripeWebhookSecret): außerhalb von
# NODE_ENV=production haben die TEST-Keys Vorrang — so kannst du im Testmodus nur die
# _TEST_-Varianten setzen, ohne die Live-Keys anzufassen. In Production greifen die
# Nicht-Test-Keys (Live).
STRIPE_TEST_SECRET_KEY=
STRIPE_WEBHOOK_TEST_SECRET=
# Alias-Schreibweise mit _TEST-Suffix wird ebenfalls akzeptiert (falls die
# kanonische STRIPE_TEST_…-Variante oben nicht gesetzt ist). Nur EINE Variante nötig.
# STRIPE_SECRET_KEY_TEST=
# STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable-Key (Testmodus pk_test_..., Live pk_live_...). Der aktuelle
# Redirect-to-Checkout-Flow braucht ihn serverseitig NICHT (Server erzeugt die
# Session, Client redirectet auf session.url). Für spätere clientseitige Stripe.js
# gehört der Public Key ins APP-Frontend — und HEALRISE ist Vite, NICHT Next.js:
# dann `VITE_STRIPE_PUBLISHABLE_KEY` in app/.env (NICHT `NEXT_PUBLIC_...`).
# Einrichtung: siehe docs/stripe_setup.md.
# Wie bei Secret/Webhook getrennt: im Testmodus die _TEST_-Variante setzen; die
# Readiness-Prüfung (validateStripeConfig) bevorzugt sie außerhalb von Production.
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_PUBLISHABLE_KEY=
# Öffentliche URL der App (Checkout-success/cancel-Redirects UND Basis für den
# Passwort-Reset-Link, P3.1). Muss auf die App zeigen, nicht auf /cms oder /admin.
APP_PUBLIC_URL=https://example.com/healrise/app
# Frontend-Basis-URL für den Passwort-Reset-Link (P3.1, hat Vorrang vor
# APP_PUBLIC_URL). Reset-Link = FRONTEND_URL/<PASSWORD_RESET_PATH>?code=... und
# wird beim Bootstrap in users-permissions.advanced.email_reset_password gesetzt.
FRONTEND_URL=https://example.com/healrise/app
# Pfad der Frontend-Reset-Seite (Default reset-password).
PASSWORD_RESET_PATH=reset-password
# Preise in Cent je Stufe, inkl. MwSt. — müssen den Brutto-Preisen aus
# Landing/App entsprechen (69/169/399 EUR); identisch zu den Code-Fallbacks
# in src/api/checkout/controllers/checkout.ts.
# STRIPE_PRICE_HEALRISE7=6900
# STRIPE_PRICE_HEALRISE14=16900
# STRIPE_PRICE_PREMIUM=39900

# E-Mail (SMTP/Postal) — Provider für Passwort-Reset & Pflicht-Mails (M-01),
# konfiguriert in config/plugins.ts (nodemailer). Lokales Postal/SMTP:
# HOST=127.0.0.1, PORT=25, SECURE=false. KEINE echten Zugangsdaten committen —
# SMTP_USERNAME/SMTP_PASSWORD nur in der echten .env setzen (leer = ohne Auth).
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
# Absender/Antwortadresse (M-01). Reihenfolge: DEFAULT_* > EMAIL_DEFAULT_* > SMTP_*
# (Rückwärtskompatibilität). Es reicht, EINE Variante zu setzen.
DEFAULT_FROM=no-reply@example.com
DEFAULT_REPLY_TO=support@example.com
EMAIL_DEFAULT_FROM=no-reply@example.com
EMAIL_DEFAULT_REPLY_TO=support@example.com
SMTP_FROM=no-reply@example.com
SMTP_REPLY_TO=support@example.com
# Postal-Webhook (Zustell-/Bounce-Events, P3.1): öffentlicher Postal-Schlüssel
# (PEM) zur RSA-Signaturprüfung des Webhooks. Aus Postal: Server → Webhooks
# bzw. dem Public-Key-Endpoint. Empfänger-Route: POST /healrise/app/api/mail/webhook
# (Caddy-Vorbereitung: deploy/caddy/healrise-postal-webhook.caddy). Ohne diesen
# Key ist der Webhook deaktiviert (503). Kein Secret — nur der ÖFFENTLICHE Key.
POSTAL_WEBHOOK_PUBLIC_KEY=
# Signatur-Digest, den dein Postal verwendet (Default sha256).
POSTAL_WEBHOOK_SIGN_ALGO=sha256

# Upload (D-04): max. Upload-Größe in Bytes (Default 5 MiB = 5242880). Lokaler
# Provider (@strapi/provider-upload-local), keine Credentials. Externes
# Object-Storage/CDN für großes Medienvolumen ist ein Betreiber-Schritt.
UPLOAD_SIZE_LIMIT_BYTES=5242880

# Auth-Rate-Limit (P4.1/L-02): Brute-Force-Schutz für POST /api/auth/*
# (Login, Registrierung, forgot-/reset-password). In-Memory pro Client-IP.
# AUTH_RATE_LIMIT_MAX: erlaubte Anfragen je Fenster (Default 10).
# AUTH_RATE_LIMIT_WINDOW_MS: Fensterbreite in ms (Default 60000 = 1 min).
# AUTH_RATE_LIMIT_ENABLED: auf "false" setzen, um komplett zu deaktivieren.
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_ENABLED=true
